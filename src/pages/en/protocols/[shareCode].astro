---
import Layout from "../../../shared/layouts/Layout.astro";
import HeaderVisualization from "../../../domains/protocols/components/ProtocolBuilder/HeaderVisualization";

const { shareCode } = Astro.params;

let protocol = null;
let fetchError = null;

try {
  const res = await fetch(
    new URL(`/api/protocols/shared/${shareCode}`, Astro.url).toString(),
  );
  if (res.ok) {
    const data = await res.json();
    protocol = {
      ...data,
      createdAt: new Date(data.createdAt),
    };
  } else {
    fetchError = "Protocolo no encontrado o no compartido.";
  }
} catch (e) {
  fetchError = "Error al cargar el protocolo.";
}

const lang = "es" as const;
---

<Layout lang={lang}>
  <section class="flex justify-center min-h-screen p-4 pt-8">
    <div class="w-full max-w-4xl space-y-6">
      {
        fetchError ? (
          <div class="bg-linear-to-br from-zinc-800 to-zinc-900 rounded-2xl p-8 border border-zinc-700/50 shadow-xl text-center">
            <svg
              class="w-12 h-12 text-zinc-600 mx-auto mb-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <p class="text-zinc-400 text-sm">{fetchError}</p>
            <a
              href="/es"
              class="mt-4 inline-block text-amber-400 text-sm underline hover:text-amber-300"
            >
              Volver al inicio
            </a>
          </div>
        ) : (
          <>
            <div class="bg-linear-to-br from-zinc-800 to-zinc-900 rounded-2xl p-6 border border-zinc-700/50 shadow-xl">
              <div class="flex items-start justify-between gap-4 flex-wrap">
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    <span class="text-emerald-400 text-[10px] font-mono border border-emerald-700/50 bg-emerald-900/20 px-2 py-0.5 rounded-full flex items-center gap-1">
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block" />
                      Compartido
                    </span>
                  </div>
                  <h1 class="text-white text-2xl font-bold">{protocol.name}</h1>
                  {protocol.description && (
                    <p class="text-zinc-400 text-sm mt-1">
                      {protocol.description}
                    </p>
                  )}
                  <p class="text-zinc-600 text-xs mt-2 font-mono">
                    {protocol.fields.length} campos · Compartido el{" "}
                    {new Date(protocol.createdAt).toLocaleDateString("es-CO", {
                      day: "2-digit",
                      month: "short",
                      year: "numeric",
                    })}
                  </p>
                </div>
                <a
                  href="/es/protocol-creator"
                  class="flex items-center gap-2 bg-zinc-700/50 hover:bg-zinc-700 border border-zinc-600/50 hover:border-zinc-500 text-zinc-300 hover:text-white text-sm font-medium px-4 py-2 rounded-xl transition-all"
                >
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                    />
                  </svg>
                  Usar como base
                </a>
              </div>
            </div>

            <div class="bg-linear-to-br from-zinc-800 to-zinc-900 rounded-2xl border border-zinc-700/50 shadow-xl overflow-hidden">
              <div class="px-5 py-3 border-b border-zinc-700/40 flex items-center gap-2">
                <svg
                  class="w-4 h-4 text-zinc-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"
                  />
                </svg>
                <h2 class="text-zinc-200 text-sm font-semibold">
                  Visualización del encabezado
                </h2>
                <span class="text-zinc-600 text-[10px] font-mono ml-auto">
                  estilo IETF RFC · 32 bits/fila
                </span>
              </div>
              <div class="p-4 md:p-6">
                <HeaderVisualization protocol={protocol} client:load />
              </div>
            </div>

            <div class="bg-linear-to-br from-zinc-800 to-zinc-900 rounded-2xl border border-zinc-700/50 shadow-xl overflow-hidden">
              <div class="px-5 py-3 border-b border-zinc-700/40">
                <h2 class="text-zinc-200 text-sm font-semibold">
                  Campos del protocolo
                </h2>
              </div>
              <div class="p-4 space-y-2">
                {protocol.fields.map((field: any, i: number) => (
                  <div class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-zinc-900/50 border border-zinc-800">
                    <span class="text-zinc-600 text-[10px] font-mono w-5 text-right shrink-0">
                      {i + 1}
                    </span>
                    <span class="text-zinc-200 text-sm font-medium truncate">
                      {field.name}
                    </span>
                    <span class="text-zinc-500 text-xs truncate flex-1">
                      {field.meaning}
                    </span>
                    <span class="text-zinc-600 text-[10px] font-mono shrink-0">
                      {field.type} · {field.sizeBytes}B
                    </span>
                  </div>
                ))}
              </div>
            </div>
          </>
        )
      }
    </div>
  </section>
</Layout>

---
import Layout from '../../shared/layouts/Layout.astro';
import { defaultLang } from '../../shared/i18n/translations';

const lang = defaultLang;
---

<Layout lang={lang}>
  <section class="max-w-4xl mx-auto px-4 py-12 text-zinc-200">
    <h1 class="text-3xl font-bold text-amber-600 mb-4">Calculadoras</h1>
    <p class="text-zinc-400">
      Selecciona una calculadora desde el menú de navegación.
    </p>
  </section>
</Layout>

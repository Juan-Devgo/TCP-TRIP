---
import { type Language, translations, defaultLang } from '../i18n/translations';

interface Props {
  lang?: Language;
}

const t = translations[Astro.props.lang || defaultLang];
---

<section class="flex justify-center items-center min-h-screen p-4">
  <div
    class="bg-linear-to-br from-zinc-800 to-zinc-900 rounded-3xl p-6 shadow-2xl w-full max-w-4xl border border-zinc-700/50"
  >
    <!-- Header -->
    <div class="text-center mb-6">
      <h2 class="text-white text-xl font-semibold mb-1">{t.subnet.title}</h2>
      <p class="text-zinc-500 text-sm">{t.subnet.subtitle}</p>
    </div>

    <!-- Input Area -->
    <div class="flex flex-col gap-4">
      <!-- Subnet toggle + Examples / Clear buttons -->
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <button
            type="button"
            id="examples-btn"
            class="flex items-center gap-1.5 bg-zinc-700/50 hover:bg-zinc-700 border border-zinc-600/50 hover:border-zinc-500 text-zinc-300 hover:text-white text-xs font-medium px-3 py-1.5 rounded-lg transition-all duration-200 cursor-pointer select-none"
          >
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
            {t.subnet.examplesBtn}
          </button>

          <button
            type="button"
            id="clear-btn"
            class="flex items-center gap-1.5 bg-zinc-700/50 hover:bg-zinc-700 border border-zinc-600/50 hover:border-zinc-500 text-zinc-300 hover:text-white text-xs font-medium px-3 py-1.5 rounded-lg transition-all duration-200 cursor-pointer select-none"
          >
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
            {t.subnet.clearBtn}
          </button>
        </div>

        <div class="flex items-center gap-2">
          <label
            for="enable-subnets"
            class="text-zinc-400 text-sm cursor-pointer select-none"
          >
            {t.subnet.enableSubnets}
          </label>
          <input
            type="checkbox"
            id="enable-subnets"
            class="w-4 h-4 accent-emerald-500 cursor-pointer"
          />
        </div>
      </div>

      <!-- IP / Mask input row -->
      <div class="flex flex-wrap items-end justify-center gap-2">
        <!-- IP Address -->
        <div class="flex flex-col gap-1">
          <label for="ip-address" class="text-zinc-400 text-xs font-medium">
            {t.subnet.ipAddress}
          </label>
          <input
            type="text"
            id="ip-address"
            name="ip-address"
            placeholder={t.subnet.ipPlaceholder}
            class="bg-zinc-900 border-2 border-zinc-700 rounded-lg px-3 py-2 text-green-400 font-mono text-lg outline-none w-64 text-center focus:border-zinc-500 transition-colors"
          />
        </div>

        <!-- Slash separator -->
        <span class="text-zinc-400 text-2xl font-bold pb-1 select-none">/</span>

        <!-- Mask container (single or dual) -->
        <div id="mask-container-single" class="flex items-end gap-2">
          <div class="flex flex-col gap-1">
            <label for="mask-input" class="text-zinc-400 text-xs font-medium">
              {t.subnet.mask}
            </label>
            <input
              type="number"
              id="mask-input"
              name="mask-input"
              min="0"
              max="32"
              placeholder={t.subnet.maskPlaceholder}
              class="bg-zinc-900 border-2 border-zinc-700 rounded-lg px-3 py-2 text-blue-400 font-mono text-lg outline-none w-32 text-center focus:border-zinc-500 transition-colors [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
            />
          </div>
        </div>

        <div id="mask-container-dual" class="hidden items-end gap-1">
          <span class="text-zinc-400 text-2xl font-bold pb-1 select-none"
            >(</span
          >
          <div class="flex flex-col gap-1">
            <label
              for="mask-input-dual"
              class="text-zinc-400 text-xs font-medium"
            >
              {t.subnet.mask}
            </label>
            <input
              type="number"
              id="mask-input-dual"
              name="mask-input-dual"
              min="0"
              max="32"
              placeholder={t.subnet.maskPlaceholder}
              class="bg-zinc-900 border-2 border-zinc-700 rounded-lg px-3 py-2 text-blue-400 font-mono text-lg outline-none w-32 text-center focus:border-zinc-500 transition-colors [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
            />
          </div>
          <span class="text-zinc-400 text-2xl font-bold pb-1 select-none"
            >+</span
          >
          <div class="flex flex-col gap-1">
            <label
              for="submask-input"
              class="text-zinc-400 text-xs font-medium"
            >
              {t.subnet.submask}
            </label>
            <input
              type="number"
              id="submask-input"
              name="submask-input"
              min="0"
              max="30"
              placeholder={t.subnet.submaskPlaceholder}
              class="bg-zinc-900 border-2 border-zinc-700 rounded-lg px-3 py-2 text-purple-400 font-mono text-lg outline-none w-32 text-center focus:border-zinc-500 transition-colors [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
            />
          </div>
          <span class="text-zinc-400 text-2xl font-bold pb-1 select-none"
            >)</span
          >
        </div>
      </div>

      <!-- Error message -->
      <p id="calc-error" class="text-red-400 text-xs text-center hidden"></p>
    </div>

    <!-- Results Table -->
    <div class="mt-8">
      <h3 class="text-zinc-300 text-lg font-semibold mb-3">
        {t.subnet.results}
      </h3>

      <!-- Skeleton table (shown when no valid data) -->
      <div id="results-skeleton">
        <div
          class="bg-zinc-900 border border-zinc-700 rounded-xl overflow-hidden"
        >
          <table class="w-full text-sm">
            <tbody>
              {
                [
                  t.subnet.ipAddressLabel,
                  t.subnet.networkAddressLabel,
                  t.subnet.classLabel,
                  t.subnet.subnetMaskLabel,
                  t.subnet.wildcardMaskLabel,
                  t.subnet.broadcastAddressLabel,
                  t.subnet.firstHostLabel,
                  t.subnet.lastHostLabel,
                  t.subnet.totalHostsLabel,
                  t.subnet.inAddrArpaLabel,
                  t.subnet.ipv6MappedLabel,
                ].map((label: string, i: number) => (
                  <tr class={i % 2 === 0 ? 'bg-zinc-900' : 'bg-zinc-800/50'}>
                    <td class="px-4 py-2 text-zinc-400 font-medium w-1/3">
                      {label}
                    </td>
                    <td class="px-4 py-2">
                      <div class="h-4 bg-zinc-700/50 rounded animate-pulse w-3/4" />
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="text-zinc-600 text-xs text-center mt-3">{t.subnet.noData}</p>
      </div>

      <!-- Real results table (hidden by default) -->
      <div id="results-table" class="hidden">
        <div
          class="bg-zinc-900 border border-zinc-700 rounded-xl overflow-hidden"
        >
          <table class="w-full text-sm">
            <tbody>
              <tr class="bg-zinc-900" id="row-ip">
                <td class="px-4 py-2 text-zinc-400 font-medium w-1/3"
                  >{t.subnet.ipAddressLabel}</td
                >
                <td class="px-4 py-2 text-green-400 font-mono" id="res-ip"></td>
              </tr>
              <tr class="bg-zinc-800/50">
                <td class="px-4 py-2 text-zinc-400 font-medium"
                  >{t.subnet.networkAddressLabel}</td
                >
                <td class="px-4 py-2 text-green-400 font-mono" id="res-network"
                ></td>
              </tr>
              <tr class="bg-zinc-900">
                <td class="px-4 py-2 text-zinc-400 font-medium"
                  >{t.subnet.classLabel}</td
                >
                <td class="px-4 py-2 text-yellow-400 font-mono" id="res-class"
                ></td>
              </tr>
              <tr class="bg-zinc-800/50">
                <td class="px-4 py-2 text-zinc-400 font-medium"
                  >{t.subnet.subnetMaskLabel}</td
                >
                <td class="px-4 py-2 text-blue-400 font-mono" id="res-mask"
                ></td>
              </tr>
              <tr class="bg-zinc-900">
                <td class="px-4 py-2 text-zinc-400 font-medium"
                  >{t.subnet.wildcardMaskLabel}</td
                >
                <td class="px-4 py-2 text-blue-400 font-mono" id="res-wildcard"
                ></td>
              </tr>
              <tr class="bg-zinc-800/50">
                <td class="px-4 py-2 text-zinc-400 font-medium"
                  >{t.subnet.broadcastAddressLabel}</td
                >
                <td
                  class="px-4 py-2 text-orange-400 font-mono"
                  id="res-broadcast"></td>
              </tr>
              <tr class="bg-zinc-900" id="row-first-host">
                <td class="px-4 py-2 text-zinc-400 font-medium"
                  >{t.subnet.firstHostLabel}</td
                >
                <td class="px-4 py-2 font-mono" id="res-first-host"></td>
              </tr>
              <tr class="bg-zinc-800/50" id="row-last-host">
                <td class="px-4 py-2 text-zinc-400 font-medium"
                  >{t.subnet.lastHostLabel}</td
                >
                <td class="px-4 py-2 font-mono" id="res-last-host"></td>
              </tr>
              <tr class="bg-zinc-900 hidden" id="row-ip-range">
                <td class="px-4 py-2 text-zinc-400 font-medium"
                  >{t.subnet.ipRangeLabel}</td
                >
                <td class="px-4 py-2 text-blue-400 font-mono" id="res-ip-range"
                ></td>
              </tr>
              <tr class="bg-zinc-800/50" id="row-total-hosts">
                <td class="px-4 py-2 text-zinc-400 font-medium"
                  >{t.subnet.totalHostsLabel}</td
                >
                <td
                  class="px-4 py-2 text-cyan-400 font-mono"
                  id="res-total-hosts"></td>
              </tr>
              <tr class="bg-zinc-900">
                <td class="px-4 py-2 text-zinc-400 font-medium"
                  >{t.subnet.inAddrArpaLabel}</td
                >
                <td
                  class="px-4 py-2 text-zinc-300 font-mono text-xs"
                  id="res-arpa"></td>
              </tr>
              <tr class="bg-zinc-900">
                <td class="px-4 py-2 text-zinc-400 font-medium"
                  >{t.subnet.ipv6MappedLabel}</td
                >
                <td
                  class="px-4 py-2 text-zinc-300 font-mono text-xs"
                  id="res-ipv6"></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Subnets Section -->
    <div id="subnets-section" class="mt-8 hidden">
      <h3 class="text-zinc-300 text-lg font-semibold mb-3">
        {t.subnet.subnetsTitle}
      </h3>

      <!-- Subnets summary table -->
      <div
        id="subnets-summary"
        class="bg-zinc-900 border border-zinc-700 rounded-xl overflow-hidden mb-4"
      >
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-800 border-b border-zinc-700">
              <th class="px-4 py-2 text-zinc-400 font-medium text-left">#</th>
              <th class="px-4 py-2 text-zinc-400 font-medium text-left"
                >{t.subnet.networkAddressLabel}</th
              >
              <th class="px-4 py-2 text-zinc-400 font-medium text-left"
                >{t.subnet.ipRangeLabel}</th
              >
              <th class="px-4 py-2 text-zinc-400 font-medium text-left"
                >{t.subnet.broadcastAddressLabel}</th
              >
              <th class="px-4 py-2 text-zinc-400 font-medium text-center"
                >{t.subnet.usable}</th
              >
            </tr>
          </thead>
          <tbody id="subnets-tbody"></tbody>
        </table>
      </div>

      <!-- Subnet accordions container -->
      <div id="subnets-accordions" class="flex flex-col gap-2"></div>
    </div>
  </div>
</section>

<script>
  import calculateIpv4 from '../lib/functions/ipv4-calculator';

  // Detect language from URL
  const isSpanish = window.location.pathname.startsWith('/es');

  const t = {
    firstSubnetReason: isSpanish
      ? 'La dirección de subred se confunde con la dirección de red'
      : 'Subnet address conflicts with the network address',
    lastSubnetReason: isSpanish
      ? 'El broadcast de subred se confunde con el broadcast de red'
      : 'Subnet broadcast conflicts with the network broadcast',
    invalidHostRange: isSpanish
      ? 'El primer host no puede ser mayor o igual al último host. La máscara es demasiado grande para esta red.'
      : 'First host cannot be greater than or equal to last host. The mask is too large for this network.',
    errInvalidIp: isSpanish
      ? 'Dirección IP inválida (formato: X.X.X.X, cada octeto entre 0-255)'
      : 'Invalid IP address (format: X.X.X.X, each octet between 0-255)',
    errInvalidMask: isSpanish
      ? 'Máscara inválida (debe ser un número entre 0 y 32)'
      : 'Invalid mask (must be a number between 0 and 32)',
    errInvalidSubmask: isSpanish
      ? 'Submáscara inválida (debe ser un número entre 1 y {max})'
      : 'Invalid submask (must be a number between 1 and {max})',
    subnetLabel: isSpanish ? 'Subred' : 'Subnet',
  };

  // DOM elements
  const enableSubnets = document.getElementById(
    'enable-subnets',
  ) as HTMLInputElement;
  const maskContainerSingle = document.getElementById(
    'mask-container-single',
  ) as HTMLDivElement;
  const maskContainerDual = document.getElementById(
    'mask-container-dual',
  ) as HTMLDivElement;

  const ipInput = document.getElementById('ip-address') as HTMLInputElement;
  const maskInput = document.getElementById('mask-input') as HTMLInputElement;
  const maskInputDual = document.getElementById(
    'mask-input-dual',
  ) as HTMLInputElement;
  const submaskInput = document.getElementById(
    'submask-input',
  ) as HTMLInputElement;

  const calcError = document.getElementById(
    'calc-error',
  ) as HTMLParagraphElement;
  const resultsSkeleton = document.getElementById(
    'results-skeleton',
  ) as HTMLDivElement;
  const resultsTable = document.getElementById(
    'results-table',
  ) as HTMLDivElement;
  const subnetsSection = document.getElementById(
    'subnets-section',
  ) as HTMLDivElement;
  const subnetsTbody = document.getElementById(
    'subnets-tbody',
  ) as HTMLTableSectionElement;
  const subnetsAccordions = document.getElementById(
    'subnets-accordions',
  ) as HTMLDivElement;

  // Result cells
  const rowIp = document.getElementById('row-ip') as HTMLTableRowElement;
  const resIp = document.getElementById('res-ip') as HTMLTableCellElement;
  const resNetwork = document.getElementById(
    'res-network',
  ) as HTMLTableCellElement;
  const resClass = document.getElementById('res-class') as HTMLTableCellElement;
  const resMask = document.getElementById('res-mask') as HTMLTableCellElement;
  const resWildcard = document.getElementById(
    'res-wildcard',
  ) as HTMLTableCellElement;
  const resBroadcast = document.getElementById(
    'res-broadcast',
  ) as HTMLTableCellElement;
  const rowFirstHost = document.getElementById(
    'row-first-host',
  ) as HTMLTableRowElement;
  const resFirstHost = document.getElementById(
    'res-first-host',
  ) as HTMLTableCellElement;
  const rowLastHost = document.getElementById(
    'row-last-host',
  ) as HTMLTableRowElement;
  const resLastHost = document.getElementById(
    'res-last-host',
  ) as HTMLTableCellElement;
  const rowIpRange = document.getElementById(
    'row-ip-range',
  ) as HTMLTableRowElement;
  const resIpRange = document.getElementById(
    'res-ip-range',
  ) as HTMLTableCellElement;
  const resTotalHosts = document.getElementById(
    'res-total-hosts',
  ) as HTMLTableCellElement;
  const resArpa = document.getElementById('res-arpa') as HTMLTableCellElement;
  const resIpv6 = document.getElementById('res-ipv6') as HTMLTableCellElement;

  // Examples data — one per class A, B, C, D, E
  const exampleIps = [
    '10.25.30.1', // A
    '172.16.50.10', // B
    '192.168.1.100', // C
    '196.18.137.1', // C
    '224.0.0.5', // D
    '240.0.0.1', // E
  ];
  const exampleMasks = [8, 16, 18, 24, 27, 29];
  const exampleSubmasks = [8, 7, 6, 5, 3, 2];
  let exampleIndex = 0;

  const examplesBtn = document.getElementById(
    'examples-btn',
  ) as HTMLButtonElement;

  examplesBtn.addEventListener('click', () => {
    const ip = exampleIps[exampleIndex]!;
    const mask = exampleMasks[exampleIndex]!;
    const submask = enableSubnets.checked ? exampleSubmasks[exampleIndex]! : 0;

    // Set IP
    ipInput.value = ip;

    // Fill mask fields
    if (submask > 0) {
      maskInputDual.value = String(mask);
      submaskInput.value = String(submask);
      maskInput.value = String(mask + submask);
    } else {
      maskInput.value = String(mask);
      maskInputDual.value = String(mask);
      submaskInput.value = '';
    }

    // Update badge to show next class
    const nextIndex = (exampleIndex + 1) % exampleIps.length;

    // Advance index
    exampleIndex = nextIndex;

    // Trigger recalculation
    recalculate();
  });

  // Clear button
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;

  clearBtn.addEventListener('click', () => {
    // Reset inputs
    ipInput.value = '';
    maskInput.value = '';
    maskInputDual.value = '';
    submaskInput.value = '';

    // Reset subnet toggle
    if (enableSubnets.checked) {
      enableSubnets.checked = false;
      enableSubnets.dispatchEvent(new Event('change'));
    }

    // Hide error
    calcError.textContent = '';
    calcError.classList.add('hidden');

    // Show skeleton, hide results
    resultsSkeleton.classList.remove('hidden');
    resultsTable.classList.add('hidden');

    // Hide subnets section
    subnetsSection.classList.add('hidden');
    subnetsTbody.innerHTML = '';
    subnetsAccordions.innerHTML = '';

    // Reset example index
    exampleIndex = 0;

    // Focus IP input
    ipInput.focus();
  });

  // Toggle subnets mode
  enableSubnets.addEventListener('change', () => {
    const isSubnet = enableSubnets.checked;
    maskContainerSingle.classList.toggle('hidden', isSubnet);
    maskContainerSingle.classList.toggle('flex', !isSubnet);
    maskContainerDual.classList.toggle('hidden', !isSubnet);
    maskContainerDual.classList.toggle('flex', isSubnet);

    // Sync mask values between single/dual
    if (isSubnet) {
      maskInputDual.value = maskInput.value;
    } else {
      maskInput.value = maskInputDual.value;
    }

    recalculate();
  });

  // Validate IP format
  function isValidIp(ip: string): boolean {
    const parts = ip.split('.');
    if (parts.length !== 4) return false;
    return parts.every((p) => {
      const n = Number(p);
      return !isNaN(n) && n >= 0 && n <= 255 && p === String(n);
    });
  }

  // Validate mask
  function isValidMask(mask: string): boolean {
    if (mask === '') return false;
    const n = Number(mask);
    return !isNaN(n) && Number.isInteger(n) && n >= 0 && n <= 32;
  }

  // Validate submask
  function isValidSubmask(submask: string, mask: number): boolean {
    if (submask === '') return false;
    const n = Number(submask);
    return !isNaN(n) && Number.isInteger(n) && n >= 1 && n <= 32 - mask;
  }

  // Compare IP strings numerically
  function ipToNum(ip: string): number {
    const p = ip.split('.').map(Number);
    return ((p[0]! << 24) | (p[1]! << 16) | (p[2]! << 8) | p[3]!) >>> 0;
  }

  function isHostRangeValid(firstHost: string, lastHost: string): boolean {
    return ipToNum(firstHost) < ipToNum(lastHost);
  }

  function showError(msg: string) {
    calcError.textContent = msg;
    calcError.classList.remove('hidden');
  }

  function hideError() {
    calcError.classList.add('hidden');
  }

  function showSkeleton() {
    resultsSkeleton.classList.remove('hidden');
    resultsTable.classList.add('hidden');
    subnetsSection.classList.add('hidden');
  }

  function showResults() {
    resultsSkeleton.classList.add('hidden');
    resultsTable.classList.remove('hidden');
  }

  // Build a subnet detail table HTML (with host and conflict validation)
  function buildSubnetTable(
    data: ReturnType<typeof calculateIpv4>,
    options?: { networkConflict?: boolean; broadcastConflict?: boolean },
  ): string {
    const hostValid = isHostRangeValid(data.firstHost, data.lastHost);
    const hostColor = hostValid ? 'text-emerald-400' : 'text-red-400';
    const hostIcon = hostValid
      ? ''
      : ` <span class="text-red-400">✘</span> <span class="text-red-400/70 text-xs">${t.invalidHostRange}</span>`;

    const netConflict = options?.networkConflict ?? false;
    const bcastConflict = options?.broadcastConflict ?? false;

    const netColor = netConflict ? 'text-red-400' : 'text-green-400';
    const netIcon = netConflict
      ? ` <span class="text-red-400">✘</span> <span class="text-red-400/70 text-xs">${t.firstSubnetReason}</span>`
      : '';

    const bcastColor = bcastConflict ? 'text-red-400' : 'text-orange-400';
    const bcastIcon = bcastConflict
      ? ` <span class="text-red-400">✘</span> <span class="text-red-400/70 text-xs">${t.lastSubnetReason}</span>`
      : '';

    const showIpRow = data.ipAddress !== data.networkAddress;

    const rows: [string, string, string, string][] = [];

    if (showIpRow) {
      rows.push(['IP', data.ipAddress, 'text-green-400', '']);
    }

    rows.push(
      [isSpanish ? 'Red' : 'Network', data.networkAddress, netColor, netIcon],
      [isSpanish ? 'Clase' : 'Class', data.class, 'text-yellow-400', ''],
      [isSpanish ? 'Máscara' : 'Mask', data.subnetMask, 'text-blue-400', ''],
      ['Wildcard', data.wildcardMask, 'text-blue-400', ''],
      ['Broadcast', data.broadcastAddress, bcastColor, bcastIcon],
      [
        isSpanish ? 'Primer Host' : 'First Host',
        data.firstHost,
        hostColor,
        hostIcon,
      ],
      [
        isSpanish ? 'Último Host' : 'Last Host',
        data.lastHost,
        hostColor,
        hostIcon,
      ],
    );

    if (hostValid) {
      rows.push([
        isSpanish ? 'Rango IPs' : 'IP Range',
        `${data.firstHost} — ${data.lastHost}`,
        'text-blue-400',
        '',
      ]);
    }

    rows.push(
      [
        isSpanish ? 'Hosts Totales' : 'Total Hosts',
        String(data.totalHosts),
        'text-cyan-400',
        '',
      ],
      ['in-addr.arpa', data.inAddrArpa, 'text-zinc-300', ''],
      [
        isSpanish ? 'IPv6 Mapeado' : 'IPv6 Mapped',
        data.ipv6Mapped,
        'text-zinc-300',
        '',
      ],
    );

    return `<table class="w-full text-sm">
      <tbody>
        ${rows
          .map(
            ([label, value, color, icon], i) => `
          <tr class="${i % 2 === 0 ? 'bg-zinc-900' : 'bg-zinc-800/50'}">
            <td class="px-4 py-2 text-zinc-400 font-medium w-1/3">${label}</td>
            <td class="px-4 py-2 ${color} font-mono">${value}${icon}</td>
          </tr>`,
          )
          .join('')}
      </tbody>
    </table>`;
  }

  function recalculate() {
    hideError();

    const ip = ipInput.value.trim();
    const isSubnetMode = enableSubnets.checked;
    const maskStr = isSubnetMode
      ? maskInputDual.value.trim()
      : maskInput.value.trim();
    const submaskStr = isSubnetMode ? submaskInput.value.trim() : '';

    // Validate IP — show error only if user has typed something
    if (!ip) {
      showSkeleton();
      return;
    }
    if (!isValidIp(ip)) {
      showError(t.errInvalidIp);
      showSkeleton();
      return;
    }

    // Validate mask — show error only if user has typed something
    if (!maskStr) {
      showSkeleton();
      return;
    }
    if (!isValidMask(maskStr)) {
      showError(t.errInvalidMask);
      showSkeleton();
      return;
    }

    const mask = Number(maskStr);

    // Validate submask if in subnet mode
    if (isSubnetMode) {
      if (!submaskStr) {
        showSkeleton();
        return;
      }
      if (!isValidSubmask(submaskStr, mask)) {
        showError(t.errInvalidSubmask.replace('{max}', String(32 - mask)));
        showSkeleton();
        return;
      }
    }

    const submask = isSubnetMode ? Number(submaskStr) : undefined;

    try {
      const result = calculateIpv4(ip, mask, submask);

      // Hide IP row if IP equals network address
      const ipEqualsNetwork = result.ipAddress === result.networkAddress;
      rowIp.classList.toggle('hidden', ipEqualsNetwork);

      // Populate main results
      resIp.textContent = result.ipAddress;
      resNetwork.textContent = result.networkAddress;
      resClass.textContent = result.class;
      resMask.textContent = result.subnetMask;
      resWildcard.textContent = result.wildcardMask;
      resBroadcast.textContent = result.broadcastAddress;
      resFirstHost.textContent = result.firstHost;
      resLastHost.textContent = result.lastHost;
      resTotalHosts.textContent = String(result.totalHosts);
      resArpa.textContent = result.inAddrArpa;
      resIpv6.textContent = result.ipv6Mapped;

      // Validate host range
      const hostValid = isHostRangeValid(result.firstHost, result.lastHost);

      if (hostValid) {
        resFirstHost.className = 'px-4 py-2 font-mono text-emerald-400';
        resLastHost.className = 'px-4 py-2 font-mono text-emerald-400';
        resFirstHost.innerHTML = result.firstHost;
        resLastHost.innerHTML = result.lastHost;
        // Show IP range
        rowIpRange.classList.remove('hidden');
        resIpRange.textContent = `${result.firstHost} — ${result.lastHost}`;
      } else {
        resFirstHost.className = 'px-4 py-2 font-mono text-red-400';
        resLastHost.className = 'px-4 py-2 font-mono text-red-400';
        resFirstHost.innerHTML = `${result.firstHost} <span class="text-red-400">✘</span> <span class="text-red-400/70 text-xs">${t.invalidHostRange}</span>`;
        resLastHost.innerHTML = `${result.lastHost} <span class="text-red-400">✘</span> <span class="text-red-400/70 text-xs">${t.invalidHostRange}</span>`;
        // Hide IP range
        rowIpRange.classList.add('hidden');
      }

      showResults();

      // Handle subnets
      if (result.subnets && result.subnets.length > 0) {
        subnetsSection.classList.remove('hidden');

        const totalSubnets = result.subnets.length;

        // Build summary table
        subnetsTbody.innerHTML = result.subnets
          .map((subnet, i) => {
            const isFirst = i === 0;
            const isLast = i === totalSubnets - 1;
            const subHostValid = isHostRangeValid(
              subnet.firstHost,
              subnet.lastHost,
            );
            const isUsable = !isFirst && !isLast && subHostValid;

            const bgClass = i % 2 === 0 ? 'bg-zinc-900' : 'bg-zinc-800/50';

            const statusIcon = isUsable
              ? '<span class="text-emerald-400 text-lg">✔</span>'
              : '<span class="text-red-400 text-lg">✘</span>';

            const rangeColor = isUsable ? 'text-blue-400' : 'text-red-400';
            const rangeText = `${subnet.firstHost} — ${subnet.lastHost}`;

            const netColor = isFirst ? 'text-red-400' : 'text-green-400';
            const netExtra = isFirst
              ? ' <span class="text-red-400">✘</span>'
              : '';
            const bcastColor = isLast ? 'text-red-400' : 'text-orange-400';
            const bcastExtra = isLast
              ? ' <span class="text-red-400">✘</span>'
              : '';

            return `<tr class="${bgClass}">
              <td class="px-4 py-2 text-zinc-300 font-mono">${i}</td>
              <td class="px-4 py-2 ${netColor} font-mono">${subnet.networkAddress}${netExtra}</td>
              <td class="px-4 py-2 ${rangeColor} font-mono text-xs">${rangeText}</td>
              <td class="px-4 py-2 ${bcastColor} font-mono">${subnet.broadcastAddress}${bcastExtra}</td>
              <td class="px-4 py-2 text-center">${statusIcon}</td>
            </tr>`;
          })
          .join('');

        // Build accordions
        subnetsAccordions.innerHTML = result.subnets
          .map((subnet, i) => {
            const isFirst = i === 0;
            const isLast = i === totalSubnets - 1;
            const subHostValid = isHostRangeValid(
              subnet.firstHost,
              subnet.lastHost,
            );
            const isUsable = !isFirst && !isLast && subHostValid;

            let reasonHtml = '';
            if (isFirst) {
              reasonHtml = `<span class="text-red-400/80 text-xs italic ml-1">— ${t.firstSubnetReason}</span>`;
            } else if (isLast) {
              reasonHtml = `<span class="text-red-400/80 text-xs italic ml-1">— ${t.lastSubnetReason}</span>`;
            } else if (!subHostValid) {
              reasonHtml = `<span class="text-red-400/80 text-xs italic ml-1">— ${t.invalidHostRange}</span>`;
            }

            const statusBadge = isUsable
              ? '<span class="bg-emerald-900/50 text-emerald-400 text-xs px-2 py-0.5 rounded-full border border-emerald-700/50">✔</span>'
              : '<span class="bg-red-900/50 text-red-400 text-xs px-2 py-0.5 rounded-full border border-red-700/50">✘</span>';

            return `<details class="group bg-zinc-900 border border-zinc-700 rounded-xl overflow-hidden">
              <summary class="flex items-center justify-between px-4 py-3 cursor-pointer select-none hover:bg-zinc-800/50 transition-colors">
                <div class="flex items-center gap-3 flex-wrap">
                  <span class="text-zinc-300 font-medium text-sm">${t.subnetLabel} ${i}</span>
                  <span class="text-zinc-500 font-mono text-xs">${subnet.networkAddress}</span>
                  ${statusBadge}
                  ${reasonHtml}
                </div>
                <svg class="w-4 h-4 text-zinc-500 transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="border-t border-zinc-700">
                ${buildSubnetTable(subnet, { networkConflict: isFirst, broadcastConflict: isLast })}
              </div>
            </details>`;
          })
          .join('');
      } else {
        subnetsSection.classList.add('hidden');
      }
    } catch (e: any) {
      showError(e.message || 'Error');
      showSkeleton();
    }
  }

  // Listen to input changes for real-time calculation
  [ipInput, maskInput, maskInputDual, submaskInput].forEach((el) => {
    el.addEventListener('input', recalculate);
  });

  // Initial state
  showSkeleton();
</script>

---
import Social from './social.astro';
import { translations, defaultLang, type Language } from '../i18n/translations';

interface Props {
  lang?: Language;
}

const { lang = defaultLang } = Astro.props;
const t = translations[lang || defaultLang];

const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/', label: t.nav.baseConverter },
  { href: '/subnet', label: t.nav.subnetCalculator },
  { href: '/ip', label: t.nav.tcpIpTools },
];

const resources = [
  { href: '/docs', label: t.footer.documentation },
  { href: '/api', label: t.footer.apiReference },
  { href: '/examples', label: t.footer.examples },
];
---

<footer
  class="bg-linear-to-r from-zinc-900 via-zinc-800 to-zinc-900 border-t border-zinc-700/50"
>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-0">
          <span class="font-bold text-2xl text-amber-700 mx-1">TCP</span>
          <span class="font-bold text-2xl text-amber-800">TR</span>
          <span class="font-bold text-2xl text-amber-700">IP</span>
        </a>
        <p class="text-zinc-500 text-sm leading-relaxed">
          {t.footer.description}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">{t.footer.tools}</h3>
        <ul class="flex flex-col gap-2">
          {
            quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-zinc-400 text-sm hover:text-amber-400 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">
          {t.footer.resources}
        </h3>
        <ul class="flex flex-col gap-2">
          {
            resources.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-zinc-400 text-sm hover:text-amber-400 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <Social title={t.footer.connect} />
    </div>

    <!-- Bottom Bar -->
    <div
      class="mt-10 pt-6 border-t border-zinc-700/50 flex flex-col md:flex-row items-center justify-between gap-4"
    >
      <p class="text-zinc-500 text-sm">
        🄯 {currentYear}
        {t.footer.copyleft}
      </p>
      <div class="flex items-center gap-6">
        <a
          href="/privacy"
          class="text-zinc-500 text-sm hover:text-zinc-300 transition-colors"
        >
          {t.footer.privacy}
        </a>
        <a
          href="/terms"
          class="text-zinc-500 text-sm hover:text-zinc-300 transition-colors"
        >
          {t.footer.terms}
        </a>
      </div>
    </div>
  </div>
</footer>
